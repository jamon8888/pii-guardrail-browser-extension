{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/scripts/claude-hooks/pre-commit-privacy-check.cjs\"",
            "timeout": 30,
            "statusMessage": "Checking privacy boundary before commit..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/scripts/claude-hooks/src-edit-privacy-scan.cjs\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/scripts/claude-hooks/rust-edit-reminder.cjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
